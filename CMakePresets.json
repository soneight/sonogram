{
    "version": 2,
    "configurePresets": [{
        "name": "base_",
        "hidden": true,
        "generator": "Ninja"
    }, {
        "name": "default",
        "inherits": "base_",
        "binaryDir": "${sourceDir}/build/",
        "cacheVariables": { "CMAKE_EXPORT_COMPILE_COMMANDS": "ON" }
    }, {
        "name": "debug",
        "inherits": "base_",
        "binaryDir": "${sourceDir}/temp/presets_/debug",
        "displayName": "Debug Config",
        "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }, {
        "name": "flash",
        "inherits": "base_",
        "binaryDir": "${sourceDir}/temp/presets_/flash",
        "displayName": "Flash Config",
        "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }],
    "buildPresets": [
        { "name": "default", "configurePreset": "default" },
        { "name": "debug", "configurePreset": "debug" },
        { "name": "flash", "configurePreset": "flash" }
    ]
}
